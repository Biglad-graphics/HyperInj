# Privy (https://privy.io — create a free app, then copy App ID and Client ID)
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here
NEXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id_here

# Execution engine URL (run execution-engine locally or deployed)
NEXT_PUBLIC_EXECUTION_ENGINE_URL=http://localhost:4000

# Agentic backend URL (run agentic-backend locally or deployed)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:8000
NEXT_PUBLIC_AGENTIC_API_URL=http://localhost:8000
