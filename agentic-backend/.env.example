# Anthropic API key — use FreeModel (https://freemodel.dev) or standard Anthropic
ANTHROPIC_API_KEY=fe_oa_...
# FreeModel endpoint (remove this line to use standard Anthropic)
ANTHROPIC_BASE_URL=https://cc.freemodel.dev

# Optional: web search for news sentiment agent
SERPAPI_API_KEY=
GOOGLE_API_KEY=
GOOGLE_CX=

# Database (defaults to SQLite — change to postgres:// for production)
DATABASE_URL=sqlite:///./hyperinj.db
