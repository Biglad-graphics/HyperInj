# ── Movement Network ──────────────────────────────────────────────────────────
MOVEMENT_NETWORK=testnet
MOVEMENT_RPC_URL=https://testnet.movementnetwork.xyz/v1

# Deployed contract address (set after `movement move publish`)
MOVEX_ADDR=0x...

# ── AI Agent Engine ───────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
REDIS_URL=redis://localhost:6379

# Private key of the agent wallet (funded with MOVE for gas)
AGENT_PRIVATE_KEY=0x...
# How much margin the agent is allowed to use per cycle (USDCx micro-units, 1e6 = $1)
AGENT_MARGIN_USDC=100000000

# ── Liquidation Bot ───────────────────────────────────────────────────────────
LIQUIDATOR_PRIVATE_KEY=0x...

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_EXECUTION_ENGINE_URL=http://localhost:4001
NEXT_PUBLIC_MOVEX_ADDR=0x...
NEXT_PUBLIC_MOVEMENT_NETWORK=testnet
